# ============================================================
# Anesis — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# OpenAI API key — obtain at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# Optional — Supabase podcast hosting
# Leave blank to generate files locally without publishing.
# ------------------------------------------------------------

# Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (preferred — bypasses Row Level Security)
SUPABASE_SECRET_KEY=your_service_role_key_here

# Anon / publishable key (fallback if secret key is not set)
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Storage bucket name (must exist in your Supabase project)
SUPABASE_PODCAST_BUCKET=podcasts

# Public URL of the podcast cover image stored in Supabase
SUPABASE_COVER_URL=https://your-project-ref.supabase.co/storage/v1/object/public/podcasts/cover.png
